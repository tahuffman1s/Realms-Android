.gradle
**/build/
!**/src/**/build/

# Ignore Gradle GUI config
gradle-app.setting


# Gradle wrapper — we use the system gradle package, not the wrapper
gradlew
gradlew.bat
gradle/wrapper/

# Cache of project
.gradletasknamecache

# Machine-specific SDK path
local.properties

# Release signing — never commit keystores or passwords
keystore.properties
*.jks
*.keystore

# Local Android tooling when ANDROID_USER_HOME points inside the repo (debug.keystore, locks)
.android-user/

# IDE / editor — machine-local (team shares convention via docs, not IDE dirs)
.idea/
*.iml
.vscode/

# Claude Code Superpowers plugin — brainstorm/session artifacts, not project source
.superpowers/

# OS junk
.DS_Store
Thumbs.db

# Profiling / heap dumps
*.hprof

# Android Studio screen recordings / macro captures
captures/

# Emacs / Vim / backup droppings
*~
*.swp
*.swo

# Eclipse Gradle plugin generated files
# Eclipse Core
.project
# JDT-specific (Eclipse Java Development Tools)
.classpath

# Kotlin compiler sessions (per-build, not source)
.kotlin/

# Generated source index (built by generateDebugSourceIndex Gradle task)
app/src/debug/kotlin/com/realmsoffate/game/debug/SourceIndex.kt

# Debug dumps pulled via the `pulldebug` fish function
/debug-dumps/
# Screenshots pulled via the `screenshot` fish function
/screenshots/
# Stray debug dumps that landed in the repo root from manual exports
debug_*.txt
